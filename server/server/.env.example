# TeamFlow backend env (EXAMPLE). Copy to ".env" and fill your own values.
# ".env" is gitignored — never commit real credentials.

# Your OWN MongoDB connection string (MongoDB Atlas free tier or local).
# If omitted, the server falls back to a local MongoDB at the URI below.
MONGODB_URI=mongodb://rohitanshuyogi:rohitanshu123@cluster0-shard-00-00.wuxw1.mongodb.net:27017,cluster0-shard-00-01.wuxw1.mongodb.net:27017,cluster0-shard-00-02.wuxw1.mongodb.net:27017/?ssl=true&replicaSet=atlas-kprml5-shard-0&authSource=admin&appName=Cluster0

# Port the API/Socket.IO server listens on
PORT=4000

# Allowed frontend origin for CORS (your React dev server / deployed URL)
CLIENT_ORIGIN=http://localhost:5173
